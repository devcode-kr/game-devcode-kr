{
  "prompt": {
    "1": {
      "class_type": "UNETLoader",
      "inputs": {
        "unet_name": "__QWEN_UNET__",
        "weight_dtype": "default"
      }
    },
    "2": {
      "class_type": "CLIPLoader",
      "inputs": {
        "clip_name": "__QWEN_CLIP__",
        "type": "qwen_image"
      }
    },
    "3": {
      "class_type": "VAELoader",
      "inputs": {
        "vae_name": "__QWEN_VAE__"
      }
    },
    "4": {
      "class_type": "LoadImage",
      "inputs": {
        "image": "__INPUT_IMAGE__"
      }
    },
    "5": {
      "class_type": "TextEncodeQwenImageEdit",
      "inputs": {
        "clip": ["2", 0],
        "prompt": "__EDIT_PROMPT__",
        "vae": ["3", 0],
        "image": ["4", 0]
      }
    },
    "6": {
      "class_type": "CLIPTextEncode",
      "inputs": {
        "text": "",
        "clip": ["2", 0]
      }
    },
    "7": {
