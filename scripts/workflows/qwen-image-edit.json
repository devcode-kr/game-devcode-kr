        "cfg": "__EDIT_CFG__",
        "sampler_name": "__EDIT_SAMPLER__",
        "scheduler": "__EDIT_SCHEDULER__",
        "positive": ["5", 0],
        "negative": ["6", 0],
        "latent_image": ["7", 0],
        "denoise": 1
      }
    },
    "9": {
      "class_type": "VAEDecode",
      "inputs": {
        "samples": ["8", 0],
        "vae": ["3", 0]
      }
    },
    "10": {
      "class_type": "SaveImage",
      "inputs": {
        "images": ["9", 0],
        "filename_prefix": "__EDIT_PREFIX__"
      }
    }
  },
  "client_id": "__CLIENT_ID__"
